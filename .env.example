# ───────────────────────────────────────────────────────────
# Chain / RPC
# ───────────────────────────────────────────────────────────
CHAIN_ID=84532                              # Base Sepolia
RPC_URL=https://sepolia.base.org
BUYER_PRIVATE_KEY=0x...
SELLER_PRIVATE_KEY=0x...
BUYER_ADDRESS=0x...                         # Optional; derived from BUYER_PRIVATE_KEY if omitted
SELLER_ADDRESS=0x...                        # Optional; derived from SELLER_PRIVATE_KEY if omitted

# ───────────────────────────────────────────────────────────
# Deployed contracts
# For local/testnet demos, `scripts/deploy_contracts.sh` can deploy MockUSDC + escrow.
# For a real Base Sepolia USDC demo, keep USDC_ADDRESS as the canonical token below.
# ───────────────────────────────────────────────────────────
ESCROW_ADDRESS=0x...
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e   # Base Sepolia USDC
AGENT_NFT_ADDRESS=0x...

# ───────────────────────────────────────────────────────────
# ERC-8004
# ───────────────────────────────────────────────────────────
ERC8004_IDENTITY_REGISTRY=0x...
ERC8004_REPUTATION_REGISTRY=0x...

# ───────────────────────────────────────────────────────────
# Gensyn AXL
# ───────────────────────────────────────────────────────────
BUYER_AXL_ENDPOINT=http://localhost:9001
SELLER_AXL_ENDPOINT=http://localhost:9002
AXL_GOSSIP_TOPIC=bazaar.rfq.v1

# ───────────────────────────────────────────────────────────
# KeeperHub
# ───────────────────────────────────────────────────────────
KEEPERHUB_API_KEY=
KEEPERHUB_MCP_ENDPOINT=https://api.keeperhub.xyz/mcp
KEEPERHUB_BUYER_WALLET_ID=
KEEPERHUB_WORKFLOW_LOCK=
KEEPERHUB_WORKFLOW_RELEASE=
KEEPERHUB_WORKFLOW_REFUND=

# ───────────────────────────────────────────────────────────
# Uniswap
# ───────────────────────────────────────────────────────────
UNISWAP_API_KEY=
UNISWAP_API_BASE=https://trade-api.gateway.uniswap.org/v1
